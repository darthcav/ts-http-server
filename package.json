{
    "name": "@darthcav/ts-http-server",
    "description": "A TypeScript HTTP server for Node.js >= 25",
    "version": "0.6.0",
    "author": {
        "name": "darthcav",
        "url": "https://github.com/darthcav"
    },
    "license": "Apache-2.0",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "src",
        "!src/__tests__",
        "dist"
    ],
    "dependencies": {
        "@darthcav/ts-utils": "0.8.5",
        "@fastify/accepts": "5.0.4",
        "@fastify/compress": "8.3.1",
        "@fastify/cors": "11.2.0",
        "@fastify/etag": "6.1.0",
        "@fastify/helmet": "13.0.2",
        "@fastify/static": "9.1.0",
        "@fastify/swagger": "9.7.0",
        "@fastify/swagger-ui": "5.2.5",
        "@fastify/view": "11.1.1",
        "@hapi/boom": "10.0.1",
        "@logtape/fastify": "2.0.5",
        "@logtape/logtape": "2.0.5",
        "ejs": "5.0.1",
        "fastify": "5.8.4",
        "jose": "6.2.2",
        "picomatch": "4.0.4",
        "yaml": "2.8.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.10",
        "@types/ejs": "3.1.5",
        "@types/node": "25.5.2",
        "@types/picomatch": "4.0.3",
        "asserttt": "1.0.1",
        "openapi-types": "12.1.3",
        "prettier": "3.8.1",
        "shx": "0.4.0",
        "typedoc": "0.28.18"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/darthcav/ts-http-server.git"
    },
    "engines": {
        "node": ">=25"
    },
    "scripts": {
        "\n===== Build =====": "",
        "clean": "shx rm -rf dist/*",
        "build": "npm run clean && tsc",
        "prepare": "npm run build",
        "\n===== Typecheck =====": "",
        "typecheck": "tsc --noEmit",
        "\n===== Start =====": "",
        "start": "node --env-file=.env.local src/start.ts",
        "\n===== Test =====": "",
        "test": "node --env-file=.env.local --test --test-reporter=spec 'src/**/*.test.ts'",
        "test:coverage": "node --env-file=.env.local --experimental-test-coverage --test 'src/**/*.test.ts'",
        "test:coverage:lcov": "shx mkdir -p coverage && node --env-file=.env.local --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout --test 'src/**/*.test.ts'",
        "\n===== Linter =====": "",
        "lint": "biome check . && prettier --check \"**/*.md\" --ignore-path .gitignore",
        "lint:fix": "biome check --write . && prettier --write \"**/*.md\" --ignore-path .gitignore",
        "\n===== TypeDoc =====": "",
        "doc": "shx rm -rf public/* && typedoc --tsconfig tsconfig.json"
    }
}
